# ==================== 敏感配置 ====================
deploy/
deploy/.env
.env
*.env.local
*.env.production

# ==================== 内部文档 / AI 协作笔记 ====================
# 只屏蔽根目录的 docs/（含你的 AI 对话笔记）
# backend/docs/ 等子目录的文档不会被屏蔽
/docs/

# ==================== 编译产物 ====================
# 只忽略后端 target/，前端 dist/ 是有意的（reviewer 可直接预览）
backend/target/
*.class
*.jar
*.war

# ==================== IDE ====================
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# ==================== 日志 ====================
logs/
*.log
npm-debug.log*

# ==================== OS ====================
.DS_Store
Thumbs.db

# ==================== 后端配置保护 ====================
# 真实 application*.yaml 含密钥，不进仓库
# application.yaml.example 不会匹配（后缀是 .example）
backend/src/main/resources/application*.yaml
!backend/src/test/resources/application-test.yaml
