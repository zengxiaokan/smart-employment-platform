<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itzk.SmartEmploymentPlatform.mapper.CompanyTodoMapper">

    <!-- 插入待办记录 -->
    <insert id="insert" parameterType="com.itzk.SmartEmploymentPlatform.pojo.entry.CompanyTodo"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO company_todos (company_id, content, event_time, created_at)
        VALUES (#{companyId}, #{content}, #{eventTime}, NOW())
    </insert>

</mapper>
